# Environment
NODE_ENV=development
WEBSITE_URL=http://localhost:3000
APPLICATION_ID=

# Better Auth - Configuration
BETTER_AUTH_SECRET=

# Database (Turso)
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Gateway Configuration
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=

# Payments and tracking
AUTUMN_SECRET_KEY=

# Apple Push Notification service (APNs) — powers server-pushed Live Activity /
# Dynamic Island updates so the driver's lock-screen card stays live even when
# the app is backgrounded or killed. Without these, Live Activity still works
# but only updates while the app is open in the foreground.
#   APNS_KEY_ID    — same Key ID as eas.json ascApiKeyId
#   APNS_TEAM_ID   — Apple Team ID (86S82A9ZPS)
#   APNS_KEY_PATH  — absolute path to the AuthKey_*.p8 file on the server
#   APNS_BUNDLE_ID — iOS bundle id (com.nvc360.uberize)
#   APNS_ENV       — "production" (TestFlight/App Store) or "sandbox" (Xcode debug builds)
APNS_KEY_ID=
APNS_TEAM_ID=86S82A9ZPS
APNS_KEY_PATH=
APNS_BUNDLE_ID=com.nvc360.uberize
APNS_ENV=production
