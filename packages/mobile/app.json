{
  "expo": {
    "icon": "./assets/icon.png",
    "android": {
      "package": "com.nvc360.uberize2",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#070b12"
      },
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiUrl": "https://uberize.ai",
      "applicationId": "nvc360-bgyv8cj",
      "eas": {
        "projectId": "6e43daa9-bb98-41e0-b7b7-9ea0e7a9ebac"
      }
    },
    "ios": {
      "bundleIdentifier": "com.nvc360.uberize2",
      "appleTeamId": "86S82A9ZPS",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "remote-notification"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "NVC360 shares your live location with dispatch while you are on shift so customers can be given accurate ETAs.",
        "NSLocationWhenInUseUsageDescription": "NVC360 shares your live location during active jobs.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#070b12"
    },
    "name": "NVC360 Driver",
    "slug": "nvc360v4",
    "owner": "nvc360",
    "version": "1.0.1",
    "scheme": "homeserve",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow NVC360 to share your live location with dispatch while you are on shift.",
          "locationWhenInUsePermission": "Allow NVC360 to share your live location during active jobs.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0ea5e9"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NVC360 to access your photos to upload job and profile images.",
          "cameraPermission": "Allow NVC360 to use the camera to capture job photos."
        }
      ],
      "expo-secure-store",
      [
        "expo-live-activity",
        {
          "enablePushNotifications": true
        }
      ]
    ],
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/6e43daa9-bb98-41e0-b7b7-9ea0e7a9ebac"
    }
  }
}
