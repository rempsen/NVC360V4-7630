{
  "name": "@template/web",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/api/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "build:smoke": "tsc --noEmit && vite build && bun run scripts/smoke-build.mjs",
    "smoke": "bun run scripts/smoke-build.mjs",
    "dev": "vite",
    "start": "bun src/server.ts",
    "lint": "cd ../.. && oxlint packages/web --deny-warnings --no-error-on-unmatched-pattern",
    "test": "bun test src/shared/__tests__ src/api/lib/__tests__ src/services/__tests__ src/api/routes/__tests__",
    "preview": "bun run build && vite preview",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/expo": "1.4.22",
    "@libsql/client": "^0.17.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@runablehq/website-runtime": "^0.10.0",
    "@tanstack/react-query": "^5.100.6",
    "@types/leaflet": "^1.9.21",
    "ai": "^6.0.196",
    "better-auth": "1.4.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dedent": "^1.7.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.10",
    "ioredis": "^5.11.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "motion": "^12.40.0",
    "pdf-lib": "^1.17.1",
    "posthog-node": "^5.35.13",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.3.5",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.11",
    "@vitejs/plugin-react": "5.1.4",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  }
}
